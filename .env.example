# Slack
SLACK_USER_TOKEN=xoxp-...
SLACK_CHANNEL_ID=C...

# Google Drive (승인 시 Google 문서 링크 읽기)
# 관리자가 웹 UI에서 Google OAuth 로그인 후 승인

# Notion (승인 시 Notion 페이지 링크 읽기)
# 기본은 공개 공유 URL을 직접 읽습니다.
# 선택: 토큰을 설정하면 공식 API를 먼저 시도하고, 실패하면 공개 URL 읽기로 fallback합니다.
# https://www.notion.so/myintegrations 에서 integration 생성 후 토큰 발급
# 공식 API를 사용할 경우 읽을 각 Notion 페이지를 integration에 "연결" / 공유해야 합니다.
# Notion database 동기화, 댓글, 첨부파일 다운로드는 1차 범위 제외
NOTION_API_TOKEN=

# Gemini
GEMINI_API_KEY=...
