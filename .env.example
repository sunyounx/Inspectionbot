# Slack
SLACK_USER_TOKEN=xoxp-...
SLACK_CHANNEL_ID=C...

# Google Drive (승인 시 Google 문서 링크 읽기)
# 관리자가 웹 UI에서 Google OAuth 로그인 후 승인

# Notion (승인 시 Notion 페이지 링크 읽기 — 공식 API만, NOTION_API_TOKEN 필수)
# https://www.notion.so/myintegrations 에서 integration 생성 후 secret_... 토큰 발급
# 읽을 각 Notion 페이지를 integration에 "연결" / 공유해야 함 (링크 공개만으로는 불가)
# Notion database 동기화, 댓글, 첨부파일 다운로드는 1차 범위 제외
NOTION_API_TOKEN=

# Gemini
GEMINI_API_KEY=...
