# Slack
SLACK_USER_TOKEN=xoxp-...
SLACK_CHANNEL_ID=C...

# Google Drive (승인 시 Google 문서 링크 읽기)
# 관리자가 웹 UI에서 Google OAuth 로그인 후 승인

# Notion (승인 시 Notion 페이지 링크 읽기) — OAuth 권장
# Public integration: https://www.notion.so/myintegrations → OAuth Domain & URIs
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_REDIRECT_URI=https://your-host/api/notion/oauth/callback
# (선택) 팀 공용 internal token — OAuth 세션 없을 때만 fallback
NOTION_API_TOKEN=
NOTION_PLAYWRIGHT_TIMEOUT_MS=8000
NOTION_PLAYWRIGHT_SCROLL=1

# Gemini
GEMINI_API_KEY=...
